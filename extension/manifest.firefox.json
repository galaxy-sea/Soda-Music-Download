{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "__MSG_extensionName__",
  "version": "0.0.0",
  "description": "__MSG_extensionDescription__",
  "icons": {
    "16": "icons/icon120.png",
    "32": "icons/icon120.png",
    "48": "icons/icon120.png",
    "64": "icons/icon120.png",
    "120": "icons/icon120.png"
  },
  "action": {
    "default_title": "__MSG_extensionName__",
    "default_icon": {
      "16": "icons/icon120.png",
      "32": "icons/icon120.png",
      "48": "icons/icon120.png",
      "64": "icons/icon120.png",
      "120": "icons/icon120.png"
    }
  },
  "permissions": [
    "downloads"
  ],
  "host_permissions": [
    "https://music.douyin.com/qishui/share/track*",
    "https://www.qishui.com/share/track*"
  ],
  "background": {
    "scripts": [
      "shared/download-utils.js",
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://music.douyin.com/qishui/share/track*",
        "https://www.qishui.com/share/track*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page.js",
        "shared/download-utils.js"
      ],
      "matches": [
        "https://music.douyin.com/*",
        "https://www.qishui.com/*"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "soda-music-download@example.com",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
